{
    "theme": {
        "animations": {
            "fadeIn": {
                "description": "Animasi muncul perlahan dari transparan menjadi jelas.",
                "keyframes": {
                    "from": {
                        "opacity": 0
                    },
                    "to": {
                        "opacity": 1
                    }
                },
                "timing": "0.8s ease-in-out forwards"
            },
            "slideUpFade": {
                "description": "Animasi masuk dari bawah ke atas sambil muncul perlahan.",
                "keyframes": {
                    "from": {
                        "opacity": 0,
                        "transform": "translateY(30px)"
                    },
                    "to": {
                        "opacity": 1,
                        "transform": "translateY(0)"
                    }
                },
                "timing": "0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards"
            },
            "bounceHover": {
                "description": "Animasi memantul pelan saat cursor diarahkan (hover), cocok untuk tombol atau ikon.",
                "keyframes": {
                    "0%": {
                        "transform": "translateY(0)"
                    },
                    "50%": {
                        "transform": "translateY(-5px)"
                    },
                    "100%": {
                        "transform": "translateY(0)"
                    }
                },
                "timing": "0.4s ease-in-out"
            },
            "typing": {
                "description": "Efek mengetik, bagus untuk judul atau headline utama.",
                "keyframes": {
                    "from": {
                        "width": "0"
                    },
                    "to": {
                        "width": "100%"
                    }
                },
                "timing": "2s steps(40, end)"
            }
        },
        "classes": {
            "heroTitle": {
                "animation": "slideUpFade 0.6s ease-out",
                "animationDelay": "0.2s"
            },
            "projectCard": {
                "animation": "fadeIn 0.8s ease-in-out",
                "transition": "transform 0.3s ease"
            },
            "projectCardHover": {
                "transform": "scale(1.03) translateY(-5px)",
                "boxShadow": "0 10px 20px rgba(0,0,0,0.15)"
            },
            "contactButton": {
                "transition": "all 0.3s ease",
                "hoverAnimation": "bounceHover 0.4s ease-in-out"
            }
        }
    }
}